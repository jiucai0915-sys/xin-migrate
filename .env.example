# 端侧模型服务地址（Ollama，OpenAI 兼容）
# 方案A 本机模型：保持默认
# 方案B 连队友局域网模型：改成 http://<队友局域网IP>:11434
OLLAMA_HOST=http://localhost:11434

# 模型名（弱机用 qwen2.5-coder:7b，强机用 qwen2.5-coder:32b）
MODEL_NAME=qwen2.5-coder:7b

# 自修复循环最大重试次数
MAX_REPAIR_RETRIES=3

# 目标数据库类型：dm(达梦) / kingbase(金仓) / postgres(模拟)
TARGET_DB=postgres

# 验证用数据库连接（用 postgres 模拟时）
VALIDATE_DB_DSN=postgresql://localhost:5432/migrate_test
